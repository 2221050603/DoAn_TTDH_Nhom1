<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sửa Địa Chỉ</title>
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/edit.css">
</head>

<body>
  <div class="container">
    <h2>Sửa Địa Chỉ</h2>

    <form action="/edit_address/<%= address.id %>" method="POST">

      <div class="form-group">
        <label for="address">Địa Chỉ</label>
        <input type="text" class="form-control" id="address" name="address" 
               value="<%= address.address %>" required>
      </div>

      <div class="form-group">
        <label for="name">Tên Điểm Thuê</label>
        <input type="text" class="form-control" id="name" name="name" 
               value="<%= address.name %>" required>
      </div>

      <!-- Nút để lấy tọa độ -->
      <button type="button" class="btn btn-info mb-3" onclick="geocode()">Cập nhật tọa độ</button>

      <div class="form-group">
        <label for="lat">Vĩ Độ</label>
        <input type="text" class="form-control" id="lat" name="lat" 
               value="<%= address.lat %>" required readonly>
      </div>

      <div class="form-group">
        <label for="long">Kinh Độ</label>
        <input type="text" class="form-control" id="long" name="long" 
               value="<%= address.long %>" required readonly>
      </div>

      <div class="form-group">
        <label for="phone_number">Số Điện Thoại</label>
        <input type="text" class="form-control" id="phone_number" 
               name="phone_number" value="<%= address.phone_number %>" required>
      </div>

      <button type="submit" class="btn btn-success">Cập Nhật</button>
    </form>

    <a href="/list_addresses" class="btn btn-secondary">Quay lại</a>
  </div>

  <script>
    async function geocode() {
      const address = document.getElementById("address").value;
      if (!address.trim()) {
        alert("Hãy nhập địa chỉ!");
        return;
      }

      const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}`;

      try {
        const response = await fetch(url);
        const data = await response.json();

        if (data.length === 0) {
          alert("Không tìm thấy tọa độ cho địa chỉ này!");
          return;
        }

        const lat = data[0].lat;
        const lng = data[0].lon;

        document.getElementById("lat").value = lat;
        document.getElementById("long").value = lng;

        alert("Đã cập nhật tọa độ thành công!");
      } catch (error) {
        alert("Lỗi trong quá trình tìm tọa độ.");
      }
    }
  </script>

</body>
</html>
