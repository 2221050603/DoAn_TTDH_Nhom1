<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đặt hàng tại <%= store.name %></title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f2f3f5;
      padding: 20px;
    }

    .container {
      max-width: 600px; 
      margin: auto;
      background: #fff;
      padding: 25px;
      border-radius: 8px;
      box-shadow: 0px 2px 10px rgba(0,0,0,0.1);
    }

    h1 {
      font-size: 22px;
      color: #333;
      margin-bottom: 10px;
    }

    p {
      font-size: 16px;
      margin: 4px 0;
    }

    label {
      font-weight: bold;
      margin-top: 10px;
      display: block;
    }

    input, textarea {
      width: 100%;
      padding: 10px;
      margin-top: 5px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 14px;
    }

    textarea {
      height: 120px;
      resize: none;
    }

    button {
      margin-top: 15px;
      padding: 10px 18px;
      background: #28a745;
      color: white;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 16px;
    }

    button:hover {
      background: #218838;
    }
  </style>
</head>

<body>
  <div class="container">
    <h1>Đặt hàng tại: <%= store.name %></h1>

    <p><strong>Địa chỉ:</strong> <%= store.address %></p>
    <p><strong>Điện thoại:</strong> <%= store.phone_number %></p>

    <form action="/submit-order" method="POST">
      
      <input type="hidden" name="storeId" value="<%= store.id %>">

      <label for="name">Tên khách hàng:</label>
      <input type="text" id="name" name="customerName" required>

      <label for="order">Chi tiết đơn hàng:</label>
      <textarea id="order" name="orderDetails" required></textarea>

      <button type="submit">Gửi đơn hàng</button>
    </form>
  </div>
</body>
</html>
