<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trang Quản Trị</title>

    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.4.1/dist/css/bootstrap.min.css">

    <!-- Leaflet -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <!-- Routing Machine -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.css" />
    <script src="https://unpkg.com/leaflet-routing-machine/dist/leaflet-routing-machine.js"></script>

    <style>
        body {
            box-shadow: 0;
        }

        .admin {
            display: flex;
        }

        .login-register {
            position: absolute;
            left: 20px;
            z-index: 2000;
        }

        #map {
            height: 650px;
            width: 1350px;
            border: 2px solid #000;
            border-radius: 10px;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);
        }

        /* Fix vị trí nút */
        .content {
            position: relative; /* Bắt buộc để absolute hoạt động đúng */
        }

        .locate-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            z-index: 5000;
            padding: 8px 15px;
            background-color: #17a2b8;
            color: white;
            border-radius: 6px;
            border: none;
        }

        .locate-btn:hover {
            background-color: #138496;
        }
    </style>
</head>

<body>

    <div class="admin">

        <!-- BUTTON LOGIN / REGISTER -->
        <div class="login-register">
            <button class="btn btn-success" onclick="openAuthModal('login')">Đăng Nhập</button>
            <button class="btn btn-primary" onclick="openAuthModal('register')">Đăng Ký</button>
        </div>

        <div class="menu">
            <marquee style="font-size: 25px;">🚗 Chúc bạn có trải nghiệm tuyệt vời với dịch vụ của chúng tôi! 🚗</marquee>

            <div class="content">

                <!-- <div class="navbar1" style="position: absolute; z-index: 1000;">
                    <h5 style="margin: 5px;">Tìm địa chỉ:</h5>
                    <div class="sreach">
                        <input type="text" id="searchInput" placeholder="nhập name or address" class="form-control">
                        <button onclick="searchFeatures()" class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div> -->

                <!-- MAP -->
                <div id="map"></div>

                <!-- LOCATION BUTTON -->
                <button id="getLocationButton" class="locate-btn btn btn-info" onclick="userLocation()">
                    Vị trí của bạn
                </button>

            </div>
        </div>

    </div>


    <!-- ==========================
            AUTH MODAL 2 TAB
    ========================== -->
<div class="modal fade" id="authModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">

      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title">Tài Khoản</h5>
        <button type="button" class="close text-white" data-dismiss="modal">&times;</button>
      </div>

      <div class="modal-body">

        <!-- Tabs -->
        <ul class="nav nav-tabs" id="authTabs">
          <li class="nav-item">
            <a class="nav-link active" id="loginTab" data-toggle="tab" href="#loginPane">Đăng Nhập</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" id="registerTab" data-toggle="tab" href="#registerPane">Đăng Ký</a>
          </li>
        </ul>

        <div class="tab-content mt-3">

          <!-- LOGIN FORM -->
          <div class="tab-pane fade show active" id="loginPane">
            <form action="/login" method="POST">
              <label>Tên đăng nhập</label>
              <input class="form-control" name="username" required minlength="8">

              <label class="mt-2">Mật khẩu</label>
              <input type="password" class="form-control" name="password" required minlength="1">

              <button class="btn btn-success w-100 mt-3" type="submit">Đăng Nhập</button>
            </form>
          </div>

          <!-- REGISTER FORM -->
          <div class="tab-pane fade" id="registerPane">
            <form id="registerForm">

              <label>Họ và tên</label>
              <input class="form-control" name="fullname" required>

              <label class="mt-2">Tên đăng nhập</label>
              <input class="form-control" name="username" required minlength="8">

              <label class="mt-2">Mật khẩu</label>
              <input type="password" class="form-control" name="password" required minlength="6">

              <label class="mt-2">Số điện thoại</label>
              <input class="form-control" name="phone" required pattern="^[0-9]{10}$">

              <button class="btn btn-primary w-100 mt-3" type="submit">Đăng Ký</button>
            </form>
          </div>

        </div>

      </div>

    </div>
  </div>
</div>


    <!-- Bootstrap + jQuery -->
    <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.4.1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- MAP SCRIPT -->
    <script src="/js/map.js"></script>

    <!-- OPEN MODAL TAB -->
    <script>
        function openAuthModal(tab) {
            $('#authModal').modal('show');

            if (tab === "login") {
                $('#loginTab').tab('show');
            } else {
                $('#registerTab').tab('show');
            }
        }
    </script>

    <!-- AJAX REGISTER -->
    <script>
document.getElementById("registerForm").addEventListener("submit", async function (e) {
    e.preventDefault();

    const data = {
        fullname: this.fullname.value,
        username: this.username.value,
        password: this.password.value,
        phone: this.phone.value
    };

    const res = await fetch("/register", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data)
    });

    const json = await res.json();

    if (json.success) {
        alert("Đăng ký thành công! Mời bạn đăng nhập.");
        $('#loginTab').tab('show');
    } else {
        alert(json.message);
    }
});

</script>

</body>
</html>
