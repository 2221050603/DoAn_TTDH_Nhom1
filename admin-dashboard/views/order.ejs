<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đặt hàng tại <%= store.name %></title>
</head>
<body>
  <h1>Đặt hàng tại: <%= store.name %></h1>
  <p>Địa chỉ: <%= store.address %></p>
  <p>Điện thoại: <%= store.phone_number %></p>

  <form action="/submit-order" method="POST">
    <input type="hidden" name="storeId" value="<%= store.id %>">
    <label for="name">Tên khách hàng:</label>
    <input type="text" id="name" name="customerName" required>
    
    <label for="order">Chi tiết đơn hàng:</label>
    <textarea id="order" name="orderDetails" required></textarea>

    <button type="submit">Gửi đơn hàng</button>
  </form>
</body>
</html>
